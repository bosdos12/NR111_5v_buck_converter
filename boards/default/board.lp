(librepcb_board 638cdf92-caaa-43c4-b466-9d0ac2ce721a
 (name "default")
 (default_font "newstroke.bene")
 (grid (interval 0.125) (unit millimeters))
 (layers (inner 0))
 (thickness 1.6)
 (solder_resist green)
 (silkscreen white)
 (silkscreen_layers_top top_legend top_names)
 (silkscreen_layers_bot bot_legend bot_names)
 (design_rules
  (default_trace_width 0.5)
  (default_via_drill_diameter 0.5)
  (stopmask_max_via_drill_diameter 3.0)
  (stopmask_clearance (ratio 0.0) (min 0.1) (max 0.1))
  (solderpaste_clearance (ratio 0.1) (min 0.0) (max 1.0))
  (pad_annular_ring (outer full) (inner auto) (ratio 0.25) (min 0.25) (max 2.0))
  (via_annular_ring (ratio 0.25) (min 0.25) (max 2.0))
 )
 (design_rule_check
  (source
   (organization 6535b730-6931-4bb8-8f41-c7785e258475 "LibrePCB Fab" "0.1")
   (design_rules f932045c-c2e9-4a71-ba5e-c7b77bd68ca0 "Standard")
  )
  (min_pcb_size 10.0 10.0)
  (max_pcb_size (double_sided 0.0 0.0) (multilayer 0.0 0.0))
  (pcb_thickness)
  (max_layers 0)
  (solder_resist)
  (silkscreen)
  (min_copper_copper_clearance 0.15)
  (min_copper_board_clearance 0.3)
  (min_copper_npth_clearance 0.25)
  (min_drill_drill_clearance 0.3)
  (min_drill_board_clearance 0.3)
  (min_silkscreen_stopmask_clearance 0.125)
  (min_copper_width 0.2)
  (min_annular_ring 0.2)
  (min_npth_drill_diameter 0.5)
  (min_pth_drill_diameter 0.3)
  (min_npth_slot_width 0.8)
  (min_pth_slot_width 0.7)
  (max_tented_via_drill_diameter 3.0)
  (min_silkscreen_width 0.15)
  (min_silkscreen_text_height 0.8)
  (min_outline_tool_diameter 1.8)
  (blind_vias_allowed false)
  (buried_vias_allowed false)
  (allowed_npth_slots single_segment_straight)
  (allowed_pth_slots single_segment_straight)
  (approvals_version "2")
  (approved minimum_width_violation
   (device 1b8b4cf9-ef25-43ca-9300-ec040261c03f)
   (polygon 14261824-8012-437b-8a60-61c52a52c297)
  )
